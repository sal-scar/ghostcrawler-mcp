{
  "name": "ghostcrawler-burp-bridge",
  "version": "0.1.0",
  "description": "Persistent SSE bridge to Burp Suite MCP. Survives MCP server restarts so Burp never sees a client disconnect (which crashes Burp).",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ghostcrawler-burp-bridge": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && node -e \"try{require('fs').chmodSync('dist/index.js',0o755)}catch(e){}\"",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.6.0",
    "eventsource": "^4.1.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3"
  }
}
