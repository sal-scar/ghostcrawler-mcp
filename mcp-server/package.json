{
  "name": "ghostcrawler-mcp",
  "version": "0.2.0",
  "description": "MCP server for Ghostcrawler browser extension — autonomous web pentest with Burp Suite integration",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ghostcrawler-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node -e \"try{require('fs').chmodSync('dist/index.js',0o755)}catch(e){}\"",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "pentest",
    "security",
    "owasp",
    "burp",
    "browser-extension"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.6.0",
    "eventsource": "^4.1.0",
    "express": "^4.18.2",
    "https-proxy-agent": "^9.0.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3"
  }
}
